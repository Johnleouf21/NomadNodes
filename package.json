{
  "name": "nomad-nodes",
  "version": "0.1.0",
  "private": true,
  "description": "Decentralized vacation rental platform - Airbnb/Booking competitor on blockchain",
  "author": "NomadNodes Team",
  "license": "MIT",
  "engines": {
    "node": ">=24.6.0",
    "pnpm": ">=10.23.0"
  },
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:contracts": "turbo run test --filter=@nomad-nodes/backend",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,sol}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,sol}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky",
    "ci": "pnpm lint && pnpm typecheck && pnpm test:contracts && pnpm build"
  },
  "devDependencies": {
    "@turbo/gen": "^2.3.3",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "prettier-plugin-solidity": "^1.4.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "**/*.{js,jsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "**/*.sol": [
      "prettier --write --plugin=prettier-plugin-solidity"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
