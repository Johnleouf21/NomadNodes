{
  "name": "@nomad-nodes/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Smart contracts for NomadNodes decentralized vacation rental platform",
  "scripts": {
    "clean": "rimraf artifacts cache coverage typechain-types dist",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "typecheck": "pnpm compile && tsc --noEmit",
    "build": "pnpm compile",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhatMainnet",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network sepolia",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "verify:sepolia": "hardhat verify --network sepolia",
    "verify:base": "hardhat verify --network base",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"contracts/**/*.sol\" \"test/**/*.ts\" \"scripts/**/*.ts\""
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.4.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.3",
    "@nomicfoundation/hardhat-ignition": "^3.0.5",
    "@nomicfoundation/hardhat-ignition-ethers": "^3.0.5",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.2",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.1",
    "@nomicfoundation/hardhat-verify": "^3.0.7",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.1",
    "chai": "^5.1.2",
    "dotenv": "^16.4.7",
    "ethers": "^6.15.0",
    "hardhat": "^3.0.15",
    "mocha": "^11.7.5",
    "rimraf": "^6.0.1",
    "typescript": "~5.9.3"
  }
}
